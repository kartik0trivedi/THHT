---

---

<section class="subscribe-section">
  <div class="subscribe-container">
    <div class="subscribe-content">
      <h2 class="subscribe-title">Get the next TH/HT in your inbox</h2>
      <p class="subscribe-desc">
        Join the mailing list to receive new writing in your inbox. No spam,
        just ideas.
      </p>
    </div>

    <!-- Success/Error Messages -->
    <div id="subscribe-success" class="form-feedback success">
      Thank you! You've been subscribed.
    </div>
    <div id="subscribe-error" class="form-feedback error">
      Oops! Something went wrong. Please try again.
    </div>

    <form id="subscribe-form" class="subscribe-form">
      <div class="input-group">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          aria-label="Email address"
          class="subscribe-input"
        />
        <button type="submit" id="subscribe-btn" class="subscribe-button">
          Subscribe
        </button>
      </div>
    </form>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("subscribe-form");
  const btn = document.getElementById("subscribe-btn");
  const successMsg = document.getElementById("subscribe-success");
  const errorMsg = document.getElementById("subscribe-error");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      btn.disabled = true;
      btn.textContent = "Subscribing...";
      successMsg.style.display = "none";
      errorMsg.style.display = "none";

      try {
        const response = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email: form.email.value }),
        });

        if (!response.ok) throw new Error("Server error");

        successMsg.style.display = "block";
        form.reset();
      } catch (error) {
        console.error("Subscription error:", error);
        errorMsg.style.display = "block";
      } finally {
        btn.disabled = false;
        btn.textContent = "Subscribe";
      }
    });
  }
</script>

<style>
  .subscribe-section {
    margin: 4rem 0;
    padding: 3rem 2rem;
    background-color: var(--paper-warm);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  /* Feedback Styles */
  .form-feedback {
    display: none;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 2rem;
    max-width: 450px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Formspree library toggles display automatically */
  [data-fs-success],
  [data-fs-error] {
    display: none;
  }

  .form-feedback.success {
    background-color: rgba(46, 204, 113, 0.08);
    color: #2e7d32;
    border: 1px solid rgba(46, 204, 113, 0.2);
  }

  .form-feedback.error {
    background-color: rgba(192, 57, 43, 0.08);
    color: var(--accent);
    border: 1px solid rgba(192, 57, 43, 0.2);
  }

  .field-error {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--accent);
    margin-top: 0.5rem;
    text-align: left;
  }

  .subscribe-container {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .subscribe-content {
    margin-bottom: 2rem;
  }

  .subscribe-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .subscribe-desc {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.6;
    max-width: 450px;
    margin: 0 auto;
  }

  .subscribe-form {
    width: 100%;
    max-width: 450px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 0.5rem;
  }

  .subscribe-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--paper);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--ink);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }

  .subscribe-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(var(--accent-rgb), 0.1);
  }

  .subscribe-button {
    padding: 0.75rem 1.5rem;
    background-color: var(--ink);
    color: var(--paper);
    border: none;
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background-color var(--transition),
      transform 0.1s ease;
  }

  .subscribe-button:hover {
    background-color: var(--ink-muted);
  }

  .subscribe-button:active {
    transform: scale(0.98);
  }

  @media (max-width: 520px) {
    .subscribe-section {
      padding: 2.5rem 1.5rem;
      margin: 3rem 0;
    }

    .input-group {
      flex-direction: column;
    }

    .subscribe-button {
      width: 100%;
    }
  }
</style>
