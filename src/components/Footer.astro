---
import { Image } from 'astro:assets';
import thhtLogo from '../assets/thht-logo.svg';

const today = new Date();
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand-link" aria-label="Go home">
        <Image src={thhtLogo} alt="THHT" class="brand-logo" />
      </a>
      <p class="tagline">Thinking Hard / Hardly Thinking</p>
    </div>
    <div class="footer-meta">
      <nav class="footer-nav" aria-label="Footer">
        <a href="/blog">Writing</a>
        <a href="/tags">Topics</a>
        <a href="/about">About</a>
        <a href="/rss.xml" title="RSS Feed">RSS</a>
      </nav>
      <p class="copyright">
        &copy; {today.getFullYear()} &mdash; Made with quiet persistence.
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--paper-warm);
    padding: 3rem var(--content-padding) 4rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    align-items: start;
    gap: 2rem;
    width: var(--content-width);
    max-width: calc(100% - var(--content-padding) * 2);
    margin: 0 auto;
  }

  .footer-brand {
    display: contents;
  }

  .brand-link {
    display: inline-flex;
    text-decoration: none;
    margin-bottom: 0;
    grid-column: 1;
    grid-row: 1;
    align-self: center;
  }

  .brand-logo {
    display: block;
    width: auto;
    height: 52px;
  }

  .tagline {
    font-size: 0.78rem;
    color: var(--ink-muted);
    font-family: var(--font-sans);
    margin: 0;
    letter-spacing: 0.02em;
    grid-column: 1;
    grid-row: 2;
    align-self: end;
  }

  .footer-meta {
    display: contents;
    text-align: right;
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
    justify-content: flex-end;
    margin-bottom: 0;
    grid-column: 2;
    grid-row: 1;
    align-self: center;
  }

  .copyright {
    font-size: 0.75rem;
    color: var(--ink-muted);
    margin: 0;
    font-family: var(--font-sans);
    grid-column: 2;
    grid-row: 2;
    align-self: end;
    text-align: right;
  }

  .footer-nav a {
    font-family: var(--font-sans);
    font-size: 0.83rem;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-nav a:hover {
    color: var(--ink);
  }

  @media (max-width: 520px) {
    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .footer-brand,
    .footer-meta {
      display: block;
      text-align: left;
    }

    .brand-link {
      margin-bottom: 0.2rem;
    }

    .footer-nav {
      justify-content: flex-start;
      margin-bottom: 0.55rem;
    }
  }
</style>
