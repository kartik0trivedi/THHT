---
/**
 * Giscus Comment Component — Integrated Version
 * 
 * This component uses a custom CSS theme from /public/styles/giscus.css
 * that matches your site's design tokens.
 */
---

<section class="giscus-container">
  <div class="giscus"></div>
</section>

<script is:inline>
  function loadGiscus() {
    const container = document.querySelector('.giscus');
    if (!container) return;

    // Get current domain for absolute CSS URL
    const themeUrl = window.location.origin + '/styles/giscus.css';

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'kartik0trivedi/THHT');
    script.setAttribute('data-repo-id', 'R_kgDOR2JmAQ');
    script.setAttribute('data-category', 'Announcements');
    script.setAttribute('data-category-id', 'DIC_kwDOR2JmAc4C5uGY');
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'top');
    script.setAttribute('data-theme', themeUrl);
    script.setAttribute('data-lang', 'en');
    script.setAttribute('data-loading', 'lazy');
    script.setAttribute('crossorigin', 'anonymous');
    script.async = true;

    container.appendChild(script);
  }

  // Load on initial navigation
  loadGiscus();

  // Re-load on Astro page transitions if you use ViewTransitions
  document.addEventListener('astro:after-swap', loadGiscus);
</script>

<style>
  .giscus-container {
    padding-top: 3rem;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
  }
</style>
