---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`404: Not Found — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .error-page {
        padding: 8rem 0;
        text-align: center;
        max-width: 600px;
        margin: 0 auto;
      }

      .error-code {
        font-size: 5rem;
        line-height: 1;
        margin-bottom: 1rem;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -0.04em;
      }

      .error-title {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        color: var(--ink-muted);
        font-style: italic;
      }

      .error-text {
        font-family: var(--font-sans);
        font-size: 1.05rem;
        color: var(--ink-muted);
        line-height: 1.6;
        margin-bottom: 2.5rem;
      }

      .action-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--ink);
        color: var(--paper);
        text-decoration: none;
        padding: 0.8rem 1.4rem;
        border-radius: 999px;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 0.95rem;
        transition: transform var(--transition), background var(--transition);
      }

      .action-link:hover {
        background: var(--accent);
        transform: translateY(-1px);
        text-decoration: none;
      }

      @media (max-width: 640px) {
        .error-page {
          padding: 5rem 0;
        }
        .error-code {
          font-size: 4rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="error-page">
        <h1 class="error-code">404</h1>
        <h2 class="error-title">Page not found</h2>
        <p class="error-text">
          Whatever you were looking for doesn't exist here. It might have been moved, deleted, or perhaps it arose from a wandering thought.
        </p>
        <a href="/" class="action-link">
          Return Home →
        </a>
      </div>
    </main>
    <Footer />
  </body>
</html>
