---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import TagList from '../../components/TagList.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('writing');

  // Collect all unique tags
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagSet.add(tag.toLowerCase().replace(/\s+/g, '-'));
    }
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) =>
          (p.data.tags ?? []).some(
            (t) => t.toLowerCase().replace(/\s+/g, '-') === tag,
          ),
        )
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`#${tag} — ${SITE_TITLE}`}
      description={`Posts tagged "${tag}"`}
    />
    <style>
      .page-header {
        padding: 3rem 0 2.5rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2.5rem;
      }

      .eyebrow {
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.6rem;
      }

      .page-header h1 { font-size: 2rem; margin-bottom: 0; }

      .post-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .post-item { border-bottom: 1px solid var(--border); }
      .post-item:first-child { border-top: 1px solid var(--border); }

      .post-link {
        display: grid;
        grid-template-columns: 1fr auto;
        grid-template-rows: auto auto auto;
        gap: 0.2rem 1.5rem;
        padding: 1.4rem 0;
        text-decoration: none;
        color: inherit;
      }

      .post-link:hover .post-title { color: var(--accent); }

      .post-title {
        font-family: var(--font-serif);
        font-size: 1.15rem;
        font-weight: 500;
        color: var(--ink);
        line-height: 1.3;
        margin: 0;
        grid-column: 1;
        grid-row: 1;
        transition: color var(--transition);
      }

      .post-desc {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        color: var(--ink-muted);
        margin: 0;
        grid-column: 1;
        grid-row: 2;
        line-height: 1.5;
      }

      .post-tags {
        grid-column: 1;
        grid-row: 3;
        padding-top: 0.5rem;
      }

      .post-date {
        font-family: var(--font-sans);
        font-size: 0.77rem;
        color: var(--ink-muted);
        white-space: nowrap;
        grid-column: 2;
        grid-row: 1;
        align-self: start;
        padding-top: 0.2rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3em;
        font-family: var(--font-sans);
        font-size: 0.82rem;
        color: var(--ink-muted);
        text-decoration: none;
        margin-top: 2.5rem;
        transition: color var(--transition);
      }

      .back-link:hover { color: var(--ink); text-decoration: none; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <p class="eyebrow">Topic</p>
        <h1>#{tag}</h1>
      </div>

      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/writing/${post.id}/`} class="post-link">
              <h2 class="post-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}
              {post.data.tags && (
                <div class="post-tags">
                  <TagList tags={post.data.tags} />
                </div>
              )}
              <span class="post-date">
                <FormattedDate date={post.data.pubDate} />
              </span>
            </a>
          </li>
        ))}
      </ul>

      <a href="/tags" class="back-link">← All topics</a>
    </main>
    <Footer />
  </body>
</html>
