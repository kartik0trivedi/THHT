---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Subscribe from '../components/Subscribe.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('writing'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: 4rem 0 3rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 3rem;
      }

      .hero-eyebrow {
        font-family: var(--font-sans);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 1rem;
      }

      .hero h1 {
        font-size: 2.6rem;
        line-height: 1.2;
        margin-bottom: 1rem;
        color: var(--ink);
      }

      .hero-desc {
        font-family: var(--font-serif);
        font-size: 1.15rem;
        color: var(--ink-muted);
        line-height: 1.7;
        max-width: 520px;
        margin: 0;
      }

      .section-label {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-muted);
        margin-bottom: 1.75rem;
      }

      .post-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .post-item {
        border-bottom: 1px solid var(--border);
      }

      .post-item:first-child {
        border-top: 1px solid var(--border);
      }

      .post-link {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.25rem 0;
        text-decoration: none;
        color: var(--ink);
        transition: background var(--transition);
        border-radius: 6px;
      }

      .post-link:hover {
        text-decoration: none;
      }

      .post-link:hover .post-title {
        color: var(--accent);
      }

      .post-title {
        font-family: var(--font-serif);
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--ink);
        line-height: 1.35;
        transition: color var(--transition);
        flex: 1;
        margin: 0;
      }

      .post-date {
        font-family: var(--font-sans);
        font-size: 0.78rem;
        color: var(--ink-muted);
        white-space: nowrap;
        flex-shrink: 0;
      }

      .view-all {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        margin-top: 2.5rem;
        font-family: var(--font-sans);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--ink);
        text-decoration: none;
        border-bottom: 1px solid var(--ink);
        padding-bottom: 2px;
        transition: color var(--transition), border-color var(--transition);
      }

      .view-all:hover {
        color: var(--accent);
        border-color: var(--accent);
        text-decoration: none;
      }

      @media (max-width: 520px) {
        .hero h1 { font-size: 2rem; }
        .post-link { flex-direction: column; gap: 0.25rem; }
        .post-date { align-self: flex-start; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <h1>Thinking Hard /<br/>Hardly Thinking</h1>
        <p class="hero-desc">
          Ideas worth muddling through
        </p>
      </div>

      <p class="section-label">Recent Writing</p>

      {posts.length === 0 ? (
        <p style="color: var(--ink-muted); font-family: var(--font-serif);">
          No posts yet. Check back soon.
        </p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/writing/${post.id}/`} class="post-link">
                <h2 class="post-title">{post.data.title}</h2>
                <span class="post-date">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}

      <a href="/writing" class="view-all">All writing →</a>

      <Subscribe />
    </main>
    <Footer />
  </body>
</html>
