---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import Comments from '../components/Comments.astro';
import Subscribe from '../components/Subscribe.astro';
import type { MarkdownHeading } from 'astro';

type Props = CollectionEntry<'writing'>['data'] & {
  headings?: MarkdownHeading[];
  readingTime?: string;
  id?: string;
  showComments?: boolean;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  toc = false,
  readingTime,
  id,
  headings = [],
  showComments = true,
} = Astro.props;

const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const showToc = toc && tocHeadings.length > 0;
const ogImage = heroImage ?? (id ? `/og/${id}.png` : undefined);
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={ogImage} />
    <style>
      .post-header {
        padding: 3.5rem 0 2.5rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 3rem;
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
      }

      .post-date {
        font-family: var(--font-sans);
        font-size: 0.82rem;
        color: var(--ink-muted);
      }

      .post-updated {
        font-family: var(--font-sans);
        font-size: 0.78rem;
        color: var(--ink-muted);
        font-style: italic;
      }

      .meta-sep {
        color: var(--border);
        font-size: 0.9rem;
      }

      .post-title {
        font-size: 2.4rem;
        line-height: 1.2;
        color: var(--ink);
        margin: 0 0 0.75rem;
        letter-spacing: -0.02em;
      }

      .post-description {
        font-family: var(--font-serif);
        font-size: 1.15rem;
        color: var(--ink-muted);
        line-height: 1.65;
        margin: 0;
        font-style: italic;
      }

      .hero-image {
        margin-bottom: 2.5rem;
      }

      .hero-image img {
        width: 100%;
        height: auto;
        border-radius: 8px;
        display: block;
        box-shadow: var(--shadow-md);
      }

      .prose {
        max-width: var(--content-width);
        margin: 0 auto;
      }

      .post-body {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 2.5rem;
      }

      .post-body.longform {
        grid-template-columns: minmax(0, 1fr) 260px;
        align-items: start;
      }

      .toc {
        position: sticky;
        top: 6.5rem;
        padding: 1rem 1.1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--paper);
        box-shadow: var(--shadow-sm);
      }

      .toc-title {
        margin: 0 0 0.9rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }

      .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .toc-list li + li {
        margin-top: 0.55rem;
      }

      .toc-list a {
        display: block;
        font-family: var(--font-sans);
        font-size: 0.92rem;
        line-height: 1.45;
        color: var(--ink-muted);
        text-decoration: none;
      }

      .toc-list a:hover {
        color: var(--ink);
        text-decoration: none;
      }

      .toc-list .depth-3 {
        padding-left: 0.9rem;
        font-size: 0.88rem;
      }

      /* Back link */
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3em;
        font-family: var(--font-sans);
        font-size: 0.82rem;
        color: var(--ink-muted);
        text-decoration: none;
        margin-bottom: 2.5rem;
        transition: color var(--transition);
      }

      .back-link:hover {
        color: var(--ink);
        text-decoration: none;
      }

      /* Code block copy button */
      .copy-code {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.25rem 0.5rem;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        background: rgba(255, 255, 255, 0.1);
        color: var(--paper);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        cursor: pointer;
        opacity: 0;
        transition: opacity var(--transition), background var(--transition);
      }

      .prose pre {
        position: relative;
      }

      .prose pre:hover .copy-code {
        opacity: 1;
      }

      .copy-code:hover {
        background: rgba(255, 255, 255, 0.2);
      }

      @media (max-width: 720px) {
        .post-title { font-size: 1.9rem; }
        .post-body.longform { grid-template-columns: minmax(0, 1fr); }
        .toc {
          position: static;
          order: -1;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <a href="/writing" class="back-link">← All writing</a>

      {heroImage && (
        <div class="hero-image">
          <Image width={1020} height={510} src={heroImage} alt="" />
        </div>
      )}

      <header class="post-header">
        <div class="post-meta">
          <span class="post-date"><FormattedDate date={pubDate} /></span>
          {readingTime && (
            <>
              <span class="meta-sep">·</span>
              <span class="post-date">{readingTime}</span>
            </>
          )}
          {updatedDate && (
            <>
              <span class="meta-sep">·</span>
              <span class="post-updated">
                Updated <FormattedDate date={updatedDate} />
              </span>
            </>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
        {description && <p class="post-description">{description}</p>}
        {tags && tags.length > 0 && (
          <div style="margin-top: 1rem;">
            <TagList tags={tags} />
          </div>
        )}
      </header>

      <div class:list={['post-body', { longform: showToc }]}>
        <article class="prose">
          <slot />
        </article>

        {showToc && (
          <aside class="toc" aria-label="Table of contents">
            <h2 class="toc-title">Table of contents</h2>
            <ol class="toc-list">
              {tocHeadings.map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class:list={[`depth-${heading.depth}`]}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </aside>
        )}
      </div>

      <Subscribe />

      {showComments && <Comments />}
    </main>
    <Footer />
    
    <script>
      let copyButtonLabel = "Copy";
      let codeBlocks = Array.from(document.querySelectorAll("pre"));

      for (let codeBlock of codeBlocks) {
        let wrapper = document.createElement("div");
        wrapper.style.position = "relative";

        let copyButton = document.createElement("button");
        copyButton.className = "copy-code";
        copyButton.innerHTML = copyButtonLabel;

        codeBlock.setAttribute("tabindex", "0");
        codeBlock.appendChild(copyButton);

        // Put wrapper around code block
        if (codeBlock.parentNode) {
          codeBlock.parentNode.insertBefore(wrapper, codeBlock);
        }
        wrapper.appendChild(codeBlock);

        copyButton.addEventListener("click", async () => {
          await copyCode(codeBlock, copyButton);
        });
      }

      async function copyCode(block: HTMLElement, button: HTMLElement) {
        let code = block.querySelector("code");
        let text = code ? code.innerText : block.innerText;

        await navigator.clipboard.writeText(text);

        // Visual feedback
        button.innerText = "Copied!";
        button.style.background = "rgba(255, 255, 255, 0.4)";

        setTimeout(() => {
          button.innerText = copyButtonLabel;
          button.style.background = "rgba(255, 255, 255, 0.1)";
        }, 1200);
      }
    </script>
  </body>
</html>
